---
import '@fontsource-variable/playfair-display';
import '@fontsource/nunito/400.css';
import '@fontsource/nunito/600.css';
import '@fontsource/nunito/700.css';
import '@fontsource/caveat/400.css';
import '@fontsource/caveat/700.css';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Nunito';
    --aw-font-serif: 'Playfair Display Variable';
    --aw-font-heading: 'Playfair Display Variable';

    --aw-color-primary: rgb(34 87 57);
    --aw-color-secondary: rgb(86 125 70);
    --aw-color-accent: rgb(193 122 55);

    --aw-color-text-heading: rgb(53 38 24);
    --aw-color-text-default: rgb(64 52 42);
    --aw-color-text-muted: rgb(64 52 42 / 66%);
    --aw-color-bg-page: rgb(252 249 243);

    --aw-color-bg-page-dark: rgb(26 22 18);

    ::selection {
      background-color: rgb(193 122 55 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Nunito';
    --aw-font-serif: 'Playfair Display Variable';
    --aw-font-heading: 'Playfair Display Variable';

    --aw-color-primary: rgb(86 125 70);
    --aw-color-secondary: rgb(34 87 57);
    --aw-color-accent: rgb(211 152 89);

    --aw-color-text-heading: rgb(245 240 232);
    --aw-color-text-default: rgb(229 220 210);
    --aw-color-text-muted: rgb(229 220 210 / 66%);
    --aw-color-bg-page: rgb(26 22 18);

    ::selection {
      background-color: rgb(193 122 55 / 40%);
      color: snow;
    }
  }

  .font-accent {
    font-family: 'Caveat', cursive;
  }
</style>
