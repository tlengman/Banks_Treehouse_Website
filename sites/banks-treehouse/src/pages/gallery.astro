---
import Layout from '~/layouts/PageLayout.astro';
import Gallery from '~/components/widgets/Gallery.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// Exterior
import imgExteriorFrontSunset from '~/assets/images/gallery/exterior-front-sunset.jpg';
import imgExteriorEntranceSunset from '~/assets/images/gallery/exterior-entrance-sunset.jpg';
import imgExteriorForestDusk from '~/assets/images/gallery/exterior-forest-dusk.jpg';
import imgBalconyTableForestView from '~/assets/images/gallery/balcony-table-forest-view.jpg';

// Interior
import imgKitchenPanoramicWindows from '~/assets/images/gallery/kitchen-panoramic-windows.jpg';
import imgLivingRoomStairsCouch from '~/assets/images/gallery/living-room-stairs-couch.jpg';
import imgKitchenCounterWindows from '~/assets/images/gallery/kitchen-counter-windows.jpg';
import imgLivingKitchenOverview from '~/assets/images/gallery/living-kitchen-overview.jpg';
import imgBedroomLoftQueenBed from '~/assets/images/gallery/bedroom-loft-queen-bed.jpg';
import imgBedroomLoftViewDown from '~/assets/images/gallery/bedroom-loft-view-down.jpg';
import imgBathroomShowerVanity from '~/assets/images/gallery/bathroom-shower-vanity.jpg';
import imgMezzanineTvDeskLoft from '~/assets/images/gallery/mezzanine-tv-desk-loft.jpg';

// Mondo Pondo
import imgEntranceMondoPondoTree from '~/assets/images/gallery/entrance-mondo-pondo-tree.jpg';
import imgMondoPondoTrunkInterior from '~/assets/images/gallery/mondo-pondo-trunk-interior.jpg';
import imgMondoPondoEntryway from '~/assets/images/gallery/mondo-pondo-entryway.jpg';
import imgKitchenTreeTrunkCabinets from '~/assets/images/gallery/kitchen-tree-trunk-cabinets.jpg';

// Hot Tub & Fire Pit
import imgHotTubSunsetView from '~/assets/images/gallery/hot-tub-sunset-view.jpg';
import imgFirePitForestSunset from '~/assets/images/gallery/fire-pit-forest-sunset.jpg';
import imgFirePitWideForest from '~/assets/images/gallery/fire-pit-wide-forest.jpg';

// Lookout & Outdoors
import imgLookoutTreehousePlatform from '~/assets/images/gallery/lookout-treehouse-platform.jpg';
import imgGiantSwingForest from '~/assets/images/gallery/giant-swing-forest.jpg';
import imgNetLoftTvPillows from '~/assets/images/gallery/net-loft-tv-pillows.jpg';
import imgForestHammockProperty from '~/assets/images/gallery/forest-hammock-property.jpg';

const metadata = {
  title: 'Gallery',
  description: 'Explore photos of Banks Treehouse — a hand-crafted TinyHome Treehouse in Banks, Idaho. See the interior, exterior, hot tub, fire pit, lookout treehouse, and surrounding pine forest.',
};

const galleryImages = [
  // Exterior
  {
    src: imgExteriorFrontSunset.src,
    alt: 'Banks Treehouse exterior, front view at sunset among Ponderosa pines',
    category: 'Exterior',
  },
  {
    src: imgExteriorEntranceSunset.src,
    alt: 'Treehouse entrance at sunset with warm light on handcrafted wood',
    category: 'Exterior',
  },
  {
    src: imgExteriorForestDusk.src,
    alt: 'Treehouse glowing through the forest at dusk',
    category: 'Exterior',
  },
  {
    src: imgBalconyTableForestView.src,
    alt: 'Balcony with teak table overlooking the pine forest',
    category: 'Exterior',
  },
  // Interior
  {
    src: imgKitchenPanoramicWindows.src,
    alt: 'Kitchen with large panoramic windows looking into the forest',
    category: 'Interior',
  },
  {
    src: imgLivingRoomStairsCouch.src,
    alt: 'Living room with steel stairs, leather couch, and kitchen behind',
    category: 'Interior',
  },
  {
    src: imgKitchenCounterWindows.src,
    alt: 'Kitchen counter detail with forest views through large windows',
    category: 'Interior',
  },
  {
    src: imgLivingKitchenOverview.src,
    alt: 'Living area with round window, barn door, and kitchen overview',
    category: 'Interior',
  },
  {
    src: imgBedroomLoftQueenBed.src,
    alt: 'Queen bed in the A-frame loft bedroom with pine wood ceiling — nearly 30ft above the ground',
    category: 'Interior',
  },
  {
    src: imgBedroomLoftViewDown.src,
    alt: 'Bedroom loft looking down with built-in storage cabinets',
    category: 'Interior',
  },
  {
    src: imgBathroomShowerVanity.src,
    alt: 'Bathroom with walk-in shower, vanity, and natural light',
    category: 'Interior',
  },
  {
    src: imgMezzanineTvDeskLoft.src,
    alt: 'Mezzanine level with TV, desk area, and net loft above',
    category: 'Interior',
  },
  // Mondo Pondo
  {
    src: imgEntranceMondoPondoTree.src,
    alt: 'Front door showing the Mondo Pondo tree visible inside the treehouse',
    category: 'Mondo Pondo',
  },
  {
    src: imgMondoPondoTrunkInterior.src,
    alt: 'Mondo Pondo tree trunk growing through the interior with ladder to upper bedroom',
    category: 'Mondo Pondo',
  },
  {
    src: imgMondoPondoEntryway.src,
    alt: 'Mondo Pondo tree framed by the entryway of the treehouse',
    category: 'Mondo Pondo',
  },
  {
    src: imgKitchenTreeTrunkCabinets.src,
    alt: 'Kitchen showing the tree trunk growing through the floor with handcrafted cabinets',
    category: 'Mondo Pondo',
  },
  // Hot Tub & Fire Pit
  {
    src: imgHotTubSunsetView.src,
    alt: 'Hot tub with sunset glowing through the pine trees',
    category: 'Hot Tub & Fire Pit',
  },
  {
    src: imgFirePitForestSunset.src,
    alt: 'Fire pit area at sunset among the Ponderosa pines',
    category: 'Hot Tub & Fire Pit',
  },
  {
    src: imgFirePitWideForest.src,
    alt: 'Wide view of the fire pit area with the treehouse visible through the forest',
    category: 'Hot Tub & Fire Pit',
  },
  // Lookout & Outdoors
  {
    src: imgLookoutTreehousePlatform.src,
    alt: 'The lookout treehouse platform built on a tree for panoramic forest views',
    category: 'Lookout & Outdoors',
  },
  {
    src: imgGiantSwingForest.src,
    alt: 'Giant blue swing hanging among the pine trees on the property',
    category: 'Lookout & Outdoors',
  },
  {
    src: imgNetLoftTvPillows.src,
    alt: 'Net loft with TV, sheepskin rug, and colorful pillows — a cozy hangout spot',
    category: 'Lookout & Outdoors',
  },
  {
    src: imgForestHammockProperty.src,
    alt: 'Forest and hammock view of the property grounds among towering pines',
    category: 'Lookout & Outdoors',
  },
];
---

<Layout metadata={metadata}>
  <Gallery
    tagline="Photo Gallery"
    title="Explore Banks Treehouse"
    subtitle="Browse photos of the hand-crafted treehouse, surrounding forest, and all the experiences that await you."
    images={galleryImages}
    categories={['Exterior', 'Interior', 'Mondo Pondo', 'Hot Tub & Fire Pit', 'Lookout & Outdoors']}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book on Airbnb',
        href: 'https://www.airbnb.com/rooms/1110989650136663921',
        target: '_blank',
        icon: 'tabler:brand-airbnb',
      },
    ]}
  >
    <Fragment slot="title">Like What You See?</Fragment>
    <Fragment slot="subtitle">
      Book your stay and see it all in person. Photos don't do it justice.
    </Fragment>
  </CallToAction>
</Layout>
