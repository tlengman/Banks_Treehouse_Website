---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Guest Waiver',
  description: 'Digital liability waiver for Banks Treehouse guests.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 mx-auto max-w-2xl">
    <div class="text-center mb-10">
      <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center rounded-2xl bg-primary/10 text-primary">
        <Icon name="tabler:file-check" class="w-10 h-10" />
      </div>
      <h1 class="text-4xl font-bold tracking-tight">Guest Waiver &amp; Rental Agreement</h1>
      <p class="text-muted mt-3">Please read and sign before or at check-in.</p>
    </div>

    <!-- Waiver Text -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 mb-6">
      <div class="prose dark:prose-invert prose-sm max-w-none space-y-4 text-sm leading-relaxed">
        <h2 class="text-lg font-bold mt-0">Property Rules Acknowledgment</h2>
        <p>
          By signing this waiver, you acknowledge that you have reviewed and agree to abide by all
          Banks Treehouse house rules, including but not limited to: a maximum of 2 guests, no pets,
          no smoking anywhere on the property, quiet hours from 10 PM to 8 AM, and no parties or
          events. Violation of any house rules may result in immediate termination of your stay
          without refund.
        </p>

        <h2 class="text-lg font-bold">Assumption of Risk &mdash; Treehouse Structure &amp; Stairs</h2>
        <p>
          You understand that Banks Treehouse is a unique, elevated structure with unconventional
          steep stairs and ladder-style access to the loft bedroom. The bedroom is located
          approximately 30 feet above the ground. You acknowledge that navigating the stairs and
          elevated areas carries inherent risk, including the risk of slipping, falling, or injury.
          You voluntarily assume all risks associated with using the stairs, loft, lookout treehouse,
          and all elevated areas of the property.
        </p>

        <h2 class="text-lg font-bold">Assumption of Risk &mdash; Hot Tub</h2>
        <p>
          Use of the hot tub is at your own risk. You acknowledge that hot tub use carries risks
          including but not limited to burns, slips, falls, drowning, and adverse health reactions.
          You agree to follow all posted hot tub instructions, including temperature guidelines and
          time limits. You will not use the hot tub while under the influence of alcohol or drugs.
          Persons with heart conditions, high blood pressure, pregnancy, or other medical concerns
          should consult a physician before use.
        </p>

        <h2 class="text-lg font-bold">Assumption of Risk &mdash; Fire Pit</h2>
        <p>
          You acknowledge that the property includes a fire pit and that open flames present inherent
          dangers. You agree to use only the designated fire pit, never leave a fire unattended,
          and fully extinguish the fire with water before leaving the area. You will check local
          burn restrictions before lighting any fire. You assume all responsibility for any injury
          or property damage resulting from fire pit use.
        </p>

        <h2 class="text-lg font-bold">Property Damage Responsibility</h2>
        <p>
          You agree that you are financially responsible for any damage to the treehouse, its
          furnishings, the hot tub, fire pit, or any other property features caused by your
          negligence or misuse during your stay. Normal wear and tear is expected; excessive
          damage will be assessed and charged accordingly.
        </p>

        <h2 class="text-lg font-bold">Wildlife &amp; Natural Environment</h2>
        <p>
          The property is located in a natural forest setting with active wildlife, including deer
          and other animals. You agree not to feed, approach, or disturb any wildlife. All food and
          trash must be secured properly. You understand that the natural environment may include
          uneven terrain, tree roots, insects, and weather-related hazards, and you voluntarily
          assume these risks.
        </p>

        <h2 class="text-lg font-bold">Emergency Procedures</h2>
        <p>
          You acknowledge that Banks Treehouse is in a remote location where emergency response
          times may be longer than in urban areas. Cell service is limited. Emergency contact
          information and the property address are provided in the guest guide. In the event of a
          medical emergency, call 911. For non-emergency property issues, contact the host using
          the information provided in your booking confirmation.
        </p>

        <h2 class="text-lg font-bold">Release of Liability</h2>
        <p>
          To the fullest extent permitted by law, you release and hold harmless the property owner,
          managers, and their agents from any claims, damages, losses, or expenses arising from your
          stay, including but not limited to personal injury, property damage, or loss of personal
          belongings, except in cases of gross negligence or willful misconduct by the property
          owner.
        </p>
      </div>
    </div>

    <!-- Waiver Form -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-xl font-bold mb-6">Sign the Waiver</h2>

      <form id="waiver-form" novalidate>
        <!-- Full Name -->
        <div class="mb-5">
          <label for="waiver-name" class="block text-sm font-medium mb-1">
            Full Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="waiver-name"
            name="name"
            required
            placeholder="Your full legal name"
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>

        <!-- Email -->
        <div class="mb-5">
          <label for="waiver-email" class="block text-sm font-medium mb-1">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="waiver-email"
            name="email"
            required
            placeholder="your@email.com"
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>

        <!-- Phone -->
        <div class="mb-5">
          <label for="waiver-phone" class="block text-sm font-medium mb-1">
            Phone <span class="text-muted text-xs">(optional)</span>
          </label>
          <input
            type="tel"
            id="waiver-phone"
            name="phone"
            placeholder="(555) 123-4567"
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>

        <!-- Date -->
        <div class="mb-5">
          <label for="waiver-date" class="block text-sm font-medium mb-1">
            Date
          </label>
          <input
            type="text"
            id="waiver-date"
            name="date"
            readonly
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 text-muted cursor-not-allowed"
          />
        </div>

        <!-- Signature -->
        <div class="mb-5">
          <label class="block text-sm font-medium mb-1">
            Signature <span class="text-red-500">*</span>
          </label>
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-2 bg-white dark:bg-slate-900">
            <canvas
              id="signature-canvas"
              width="300"
              height="150"
              class="w-full border border-dashed border-gray-300 dark:border-gray-600 rounded cursor-crosshair touch-none"
              style="max-width: 300px; height: 150px;"
            ></canvas>
            <button
              type="button"
              id="clear-signature"
              class="mt-2 text-sm text-primary hover:text-accent underline"
            >
              Clear Signature
            </button>
          </div>
          <p class="text-xs text-muted mt-1">Draw your signature using your mouse or finger.</p>
        </div>

        <!-- Agreement Checkbox -->
        <div class="mb-6 flex items-start gap-3">
          <input
            type="checkbox"
            id="waiver-agreed"
            name="agreed"
            required
            class="mt-1 cursor-pointer w-4 h-4 rounded border-gray-300 dark:border-gray-600"
          />
          <label for="waiver-agreed" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            I have read and agree to the terms above. <span class="text-red-500">*</span>
          </label>
        </div>

        <!-- Submit Button -->
        <div class="grid">
          <button
            type="submit"
            id="waiver-submit"
            class="btn-primary py-3 px-6 rounded-lg font-semibold text-white bg-primary hover:bg-secondary transition-colors duration-200"
          >
            Sign Waiver
          </button>
        </div>
      </form>

      <!-- Status Messages -->
      <div id="waiver-success" class="hidden mt-6 p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
        <div class="flex items-center gap-2">
          <Icon name="tabler:circle-check" class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0" />
          <p class="text-green-700 dark:text-green-300 font-medium">Waiver signed successfully. Thank you!</p>
        </div>
      </div>

      <div id="waiver-error" class="hidden mt-6 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800">
        <div class="flex items-center gap-2">
          <Icon name="tabler:alert-circle" class="w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0" />
          <p id="waiver-error-text" class="text-red-700 dark:text-red-300 font-medium">Something went wrong. Please try again.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Date auto-fill ---
    const dateInput = document.getElementById('waiver-date') as HTMLInputElement;
    if (dateInput) {
      const now = new Date();
      dateInput.value = now.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    }

    // --- Signature Canvas ---
    const canvas = document.getElementById('signature-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    let isDrawing = false;
    let hasSignature = false;

    if (ctx) {
      ctx.strokeStyle = '#1a1612';
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      // Check for dark mode and adjust stroke color
      if (document.documentElement.classList.contains('dark')) {
        ctx.strokeStyle = '#e5dcd2';
      }

      function getPosition(e: MouseEvent | TouchEvent): { x: number; y: number } {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;

        if (e instanceof TouchEvent) {
          const touch = e.touches[0];
          return {
            x: (touch.clientX - rect.left) * scaleX,
            y: (touch.clientY - rect.top) * scaleY,
          };
        }
        return {
          x: (e.clientX - rect.left) * scaleX,
          y: (e.clientY - rect.top) * scaleY,
        };
      }

      function startDrawing(e: MouseEvent | TouchEvent) {
        e.preventDefault();
        isDrawing = true;
        const pos = getPosition(e);
        ctx!.beginPath();
        ctx!.moveTo(pos.x, pos.y);
      }

      function draw(e: MouseEvent | TouchEvent) {
        if (!isDrawing) return;
        e.preventDefault();
        const pos = getPosition(e);
        ctx!.lineTo(pos.x, pos.y);
        ctx!.stroke();
        hasSignature = true;
      }

      function stopDrawing() {
        isDrawing = false;
      }

      // Mouse events
      canvas.addEventListener('mousedown', startDrawing);
      canvas.addEventListener('mousemove', draw);
      canvas.addEventListener('mouseup', stopDrawing);
      canvas.addEventListener('mouseleave', stopDrawing);

      // Touch events
      canvas.addEventListener('touchstart', startDrawing, { passive: false });
      canvas.addEventListener('touchmove', draw, { passive: false });
      canvas.addEventListener('touchend', stopDrawing);
      canvas.addEventListener('touchcancel', stopDrawing);

      // Clear button
      const clearBtn = document.getElementById('clear-signature');
      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          ctx!.clearRect(0, 0, canvas.width, canvas.height);
          hasSignature = false;
        });
      }
    }

    // --- Form Submission ---
    const form = document.getElementById('waiver-form') as HTMLFormElement;
    const submitBtn = document.getElementById('waiver-submit') as HTMLButtonElement;
    const successEl = document.getElementById('waiver-success') as HTMLDivElement;
    const errorEl = document.getElementById('waiver-error') as HTMLDivElement;
    const errorText = document.getElementById('waiver-error-text') as HTMLParagraphElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Hide previous messages
        successEl.classList.add('hidden');
        errorEl.classList.add('hidden');

        const name = (document.getElementById('waiver-name') as HTMLInputElement).value.trim();
        const email = (document.getElementById('waiver-email') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('waiver-phone') as HTMLInputElement).value.trim();
        const date = (document.getElementById('waiver-date') as HTMLInputElement).value;
        const agreed = (document.getElementById('waiver-agreed') as HTMLInputElement).checked;

        // Client-side validation
        if (!name) {
          showError('Please enter your full name.');
          return;
        }

        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          showError('Please enter a valid email address.');
          return;
        }

        if (!hasSignature) {
          showError('Please provide your signature.');
          return;
        }

        if (!agreed) {
          showError('You must agree to the terms before signing.');
          return;
        }

        // Get signature as base64
        const signature = canvas.toDataURL('image/png');

        // Disable submit button
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';

        try {
          const response = await fetch('/api/waiver', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, phone, date, signature, agreed }),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            successEl.classList.remove('hidden');
            form.classList.add('hidden');
          } else {
            showError(data.error || 'Something went wrong. Please try again.');
          }
        } catch {
          showError('Unable to submit the waiver. Please check your connection and try again.');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Sign Waiver';
        }
      });
    }

    function showError(message: string) {
      errorText.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
</script>
