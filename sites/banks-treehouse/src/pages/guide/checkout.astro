---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Checkout Guide',
  description: 'Checkout instructions and checklist for Banks Treehouse guests.',
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:py-16 mx-auto max-w-2xl">
    <a href="/guide" class="inline-flex items-center gap-1 text-sm text-muted hover:text-primary mb-8">
      <Icon name="tabler:arrow-left" class="w-4 h-4" />
      Back to Guide
    </a>

    <div class="text-center mb-10">
      <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center rounded-2xl bg-primary/10 text-primary">
        <Icon name="tabler:door-exit" class="w-10 h-10" />
      </div>
      <h1 class="text-4xl font-bold tracking-tight">Checkout</h1>
    </div>

    <div class="bg-amber-50 dark:bg-amber-900/20 rounded-2xl border border-amber-200 dark:border-amber-800 p-6 mb-8 text-center">
      <p class="text-sm text-muted uppercase tracking-wide mb-1">Checkout Time</p>
      <p class="text-4xl font-bold text-amber-700 dark:text-amber-400">11:00 AM</p>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-xl font-semibold mb-5">Checkout Checklist</h2>
      <ul class="space-y-4 text-lg">
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Strip bed linens</strong> and leave them in a pile on the bed or floor.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Start the dishwasher</strong> if there are dishes. Place any hand-wash items in the sink.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Take out the trash</strong> and place bags in the bear-proof bin outside.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Turn off all lights</strong> and any space heaters.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Lock the door</strong> when you leave. The smartlock will auto-lock after a few minutes, but please lock it manually to be safe.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Hot tub cover on</strong> and secured.</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="tabler:square" class="w-6 h-6 text-muted mt-0.5 flex-shrink-0" />
          <span><strong>Fire pit</strong> fully extinguished if used (douse with water).</span>
        </li>
      </ul>
    </div>

    <div class="mt-8 text-center text-muted">
      <p class="text-lg">Thank you for staying at Banks Treehouse!</p>
      <p class="text-sm mt-1">We'd love a review if you had a great time.</p>
    </div>
  </section>
</Layout>
