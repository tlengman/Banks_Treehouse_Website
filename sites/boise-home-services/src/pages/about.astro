---
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Us',
  description:
    "Boise Home Services is a locally-owned home maintenance and repair company serving the Treasure Valley. Learn about our team, values, and commitment to quality.",
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About Us"
    image={{
      src: 'https://images.unsplash.com/photo-1617420258879-48850c49a1d2?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Boise Idaho skyline with foothills in the background',
    }}
  >
    <Fragment slot="title">
      Your Neighbors in <span class="text-accent dark:text-white">Home Care</span>
    </Fragment>

    <Fragment slot="subtitle">
      Boise Home Services is a locally-owned company rooted in the Treasure Valley community. We're homeowners ourselves,
      and we started this business because we believe everyone deserves honest, reliable home services at a fair price. Most
      of our work comes from referrals and repeat customers — and that's exactly the way we like it.
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Projects Completed', amount: '500+' },
      { title: 'Years in Boise', amount: '15+' },
      { title: 'Average Rating', amount: '4.9★' },
      { title: 'Response Time', amount: '24hr' },
    ]}
  />

  <Content
    isReversed
    tagline="Our Story"
    title="Built on Trust, One Home at a Time"
    items={[
      { title: 'Started by local homeowners who saw a need' },
      { title: 'Built on referrals and repeat customers' },
      { title: 'Invested in our team through ongoing training' },
      { title: 'Committed to the Treasure Valley community' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80',
      alt: 'Beautiful craftsman-style homes in a Boise neighborhood',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">A Company Born from Need</h3>
      We started Boise Home Services after too many experiences with contractors who didn't return calls, padded estimates, or
      left jobs half-finished. We knew the Treasure Valley deserved better. So we built a company around the principles we'd
      want as customers: show up when you say you will, do what you promised, and charge a fair price. Fifteen years later,
      most of our business still comes from neighbors telling neighbors — and that says more than any advertisement.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    tagline="What We Believe"
    title="Values That Guide Every Job"
    items={[
      { title: 'Honest estimates — no surprise charges, ever' },
      { title: 'Quality workmanship — backed by warranty' },
      { title: 'Respect your home — clean jobsites, always' },
      { title: 'Community first — supporting local causes and businesses' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521737711867-e3b97375f902?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80',
      alt: 'Team collaborating on a project together',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">More Than Words on a Wall</h3>
      Our values aren't aspirational — they're the rules we live by every day. We'd rather lose a job by being honest about
      what it costs than win one by hiding fees. We'd rather spend an extra hour cleaning up than leave a mess in your
      home. These aren't just policies; they're the reason our customers keep calling us back.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Features2
    tagline="Why We're Different"
    title="What Sets Us Apart"
    columns={3}
    items={[
      {
        title: 'Licensed & Insured',
        description: 'Full Idaho licensing and liability coverage on every job. Your home and our team are always protected.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Background-Checked Team',
        description: 'Every team member is vetted and background-checked. You can feel safe having us in your home.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Local Knowledge',
        description: "We know Boise homes, neighborhoods, and building codes. That local expertise saves you time and money.",
        icon: 'tabler:map-pin',
      },
      {
        title: 'Transparent Pricing',
        description: 'Detailed written estimates before work begins. What we quote is what you pay — no hidden fees.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Satisfaction Guarantee',
        description: "If you're not happy with the work, we come back and make it right. No arguments, no runaround.",
        icon: 'tabler:thumb-up',
      },
      {
        title: 'On-Time & Clean',
        description: "We show up when we say we will and clean up when we're done. Your time and your home are respected.",
        icon: 'tabler:clock',
      },
    ]}
  />

  <Steps2
    title="What You Can Expect from Every Project"
    callToAction={{ text: 'Get Started', href: '/get-estimate' }}
    items={[
      {
        title: 'Clear communication from start to finish',
        description: "We keep you informed at every stage — no guessing about timelines, costs, or what's happening next.",
      },
      {
        title: 'Detailed written estimates before work begins',
        description: 'You know exactly what the job will cost before we pick up a tool. If anything changes, we discuss it with you first.',
      },
      {
        title: 'Professional crews who respect your home and your time',
        description: 'Our team is trained, uniformed, and courteous. We protect your floors, move your furniture, and clean up after ourselves.',
      },
      {
        title: 'Follow-up to ensure your complete satisfaction',
        description: "After the job is done, we check in to make sure everything is perfect. Your satisfaction isn't just a goal — it's our guarantee.",
      },
    ]}
  />

  <CallToAction
    title="Let's Talk About Your Home"
    subtitle="Whether it's a small fix or a big project, we'd love to hear from you."
    actions={[
      { variant: 'primary', text: 'Get Free Estimate', href: '/get-estimate', icon: 'tabler:clipboard-check' },
      { text: 'Call (208) XXX-XXXX', href: 'tel:+1208XXXXXXX', icon: 'tabler:phone' },
    ]}
  />
</Layout>
