---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Us',
  description:
    "Get in touch with Boise Home Services. Call, email, or send us a message. Serving the Treasure Valley for all your home maintenance and repair needs.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact Us"
    title="Let's Get in Touch"
    subtitle="Have a question or ready to start a project? Reach out — we'd love to hear from you."
  />

  <ContactUs
    id="form"
    title="Send Us a Message"
    subtitle="We typically respond within a few hours during business days."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
      {
        type: 'tel',
        name: 'phone',
        label: 'Phone',
      },
      {
        type: 'text',
        name: 'subject',
        label: 'Subject',
      },
    ]}
    textarea={{
      label: 'Tell us about your project or question',
    }}
    disclaimer={{
      label:
        "By submitting, you agree to our <a href='/privacy' class='underline'>privacy policy</a>.",
    }}
    button="Send Message"
    description="Prefer to talk? Call us at **(208) XXX-XXXX**"
  />

  <Features2
    title="Other Ways to Reach Us"
    columns={3}
    items={[
      {
        title: 'Phone',
        description: '(208) XXX-XXXX<br/>Mon–Fri 7am–6pm, Sat 8am–2pm',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description: 'info@boisehome.services<br/>We respond within a few hours',
        icon: 'tabler:mail',
      },
      {
        title: 'Office Hours',
        description: 'Mon–Fri: 7:00 AM – 6:00 PM<br/>Saturday: 8:00 AM – 2:00 PM',
        icon: 'tabler:clock',
      },
      {
        title: 'Service Area',
        description: 'Boise, Meridian, Eagle, Nampa, Caldwell, Star, Kuna',
        icon: 'tabler:map-pin',
      },
      {
        title: 'AI Assistant',
        description: 'Get instant answers about our services<br/>Available 24/7',
        icon: 'tabler:message-chatbot',
      },
      {
        title: 'Emergency Service',
        description: 'Available for urgent repairs<br/>Call for same-day availability',
        icon: 'tabler:urgent',
      },
    ]}
  />
</Layout>
