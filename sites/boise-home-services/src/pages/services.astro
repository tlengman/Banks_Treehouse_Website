---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Our Services',
  description:
    "Browse our full range of home services — handyman, plumbing, electrical, painting, remodeling, and seasonal maintenance. Serving the Treasure Valley.",
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Our Services"
    title="Home Services You Can Count On"
    subtitle="From small repairs to major renovations, our skilled team handles every aspect of home maintenance and improvement. Browse our services below or tell us what you need."
    actions={[{ variant: 'primary', text: 'Get Free Estimate', href: '/get-estimate' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1581783898377-1c85bf937427?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Professional home improvement tools organized on a workbench',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    tagline="What We Offer"
    title="Full-Service Home Care"
    columns={3}
    items={[
      {
        title: 'Handyman Services',
        description:
          'From furniture assembly to drywall repair, our handyman team tackles the jobs that keep your home in top shape. No job is too small — we show up on time, get it done right, and clean up when we leave.',
        icon: 'tabler:tool',
        callToAction: { text: 'Learn more', href: '/services/handyman' },
      },
      {
        title: 'Plumbing',
        description:
          "Leaky faucets, clogged drains, water heater issues — our licensed plumbers solve problems fast and prevent future headaches. We diagnose accurately and fix it right the first time.",
        icon: 'tabler:droplet',
        callToAction: { text: 'Learn more', href: '/services/plumbing' },
      },
      {
        title: 'Electrical',
        description:
          'Safe, code-compliant electrical work from outlet installation to panel upgrades. Our licensed electricians do it right — no shortcuts, no guesswork, just reliable results.',
        icon: 'tabler:bolt',
        callToAction: { text: 'Learn more', href: '/services/electrical' },
      },
      {
        title: 'Painting',
        description:
          'Transform your space with professional interior and exterior painting. Clean lines, quality paint, lasting results. We prep thoroughly and leave your home looking its best.',
        icon: 'tabler:paint',
        callToAction: { text: 'Learn more', href: '/services/painting' },
      },
      {
        title: 'Remodeling',
        description:
          'Kitchen and bathroom remodels, flooring, tile, and custom projects that add value and comfort to your home. From concept to completion, we manage every detail.',
        icon: 'tabler:home-cog',
        callToAction: { text: 'Learn more', href: '/services/remodeling' },
      },
      {
        title: 'Seasonal Maintenance',
        description:
          "Protect your investment with seasonal inspections, winterization, and preventive maintenance tailored to Idaho's climate. Catch small issues before they become big problems.",
        icon: 'tabler:snowflake',
        callToAction: { text: 'Learn more', href: '/services/seasonal-maintenance' },
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Our Approach"
    title="The Boise Home Services Difference"
    items={[
      { title: 'Free estimates and transparent pricing' },
      { title: 'Licensed and fully insured' },
      { title: 'Clean and respectful of your home' },
      { title: 'Warranties on all work' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80',
      alt: 'Professional contractor at a clean, organized job site',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Quality You Can See</h3>
      We believe great work speaks for itself. Every project starts with a thorough assessment and clear communication about
      scope, timeline, and cost. Our crews maintain clean jobsites, respect your property, and stand behind every job with a
      written warranty.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Where We Work"
    title="Proudly Serving the Treasure Valley"
    items={[
      { title: 'Boise (including North End, Bench, West Boise)' },
      { title: 'Meridian' },
      { title: 'Eagle' },
      { title: 'Nampa' },
      { title: 'Caldwell' },
      { title: 'Star' },
      { title: 'Kuna' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1617420258879-48850c49a1d2?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80',
      alt: 'Scenic Boise Idaho foothills at sunset',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Your Local Home Services Team</h3>
      We're based right here in the Treasure Valley and proudly serve homeowners across the greater Boise metropolitan area.
      Whether you're in downtown Boise or out in Caldwell, our team travels to you with the same commitment to quality and
      professionalism.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Not Sure Which Service You Need?"
    subtitle="Describe your project and we'll point you in the right direction — or chat with our AI assistant for instant answers."
    actions={[
      {
        variant: 'primary',
        text: 'Get Free Estimate',
        href: '/get-estimate',
      },
      {
        text: 'Chat with Us',
        href: '/contact',
        icon: 'tabler:message-circle',
      },
    ]}
  />
</Layout>
