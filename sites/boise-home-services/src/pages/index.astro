---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Boise Home Services | Trusted Home Repair & Maintenance in the Treasure Valley',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Trusted Home Services in the Treasure Valley"
    actions={[
      {
        variant: 'primary',
        text: 'Get a Free Estimate',
        href: '/get-estimate',
        icon: 'tabler:clipboard-check',
      },
      { text: 'Our Services', href: '/services' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
      alt: 'Beautiful craftsman home exterior in the Pacific Northwest',
    }}
  >
    <Fragment slot="title">
      Your Home Deserves <span class="text-accent highlight">Expert Care</span>
    </Fragment>

    <Fragment slot="subtitle">
      Professional maintenance, repair, and improvement services for homeowners across Boise, Meridian, Eagle, and the
      Treasure Valley. Licensed, insured, and committed to quality.
    </Fragment>
  </Hero2>

  <!-- Note Widget ******************* -->

  <Note
    icon="tabler:info-square"
    title="Serving Boise, Meridian, Eagle, Nampa, Caldwell, Star & Kuna."
    description="Licensed & Insured."
  />

  <!-- Features Widget *************** -->

  <Features
    id="services"
    tagline="What We Do"
    title="Comprehensive Home Services"
    subtitle="From quick fixes to full remodels, we handle it all so you can enjoy your home."
    columns={2}
    items={[
      {
        title: 'Handyman Services',
        description:
          'General repairs, furniture assembly, drywall patching, and everything in between. No job is too small for our experienced team.',
        icon: 'tabler:tool',
      },
      {
        title: 'Plumbing',
        description:
          'Leak repair, fixture installation, water heaters, and drain cleaning. We keep your water flowing and your home dry.',
        icon: 'tabler:droplet',
      },
      {
        title: 'Electrical',
        description:
          'Outlet installation, lighting, ceiling fans, and panel upgrades. Safe, code-compliant electrical work you can trust.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Painting',
        description:
          'Interior and exterior painting, cabinet refinishing, and deck staining. Transform your space with a fresh, professional finish.',
        icon: 'tabler:paint',
      },
      {
        title: 'Remodeling',
        description:
          'Kitchen and bathroom remodels, flooring, tile work, and custom projects. Bring your vision to life with expert craftsmanship.',
        icon: 'tabler:home-cog',
      },
      {
        title: 'Seasonal Maintenance',
        description:
          'Winterization, spring inspections, gutter cleaning, and weatherproofing. Protect your home year-round with proactive care.',
        icon: 'tabler:snowflake',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Why Choose Us"
    title="Why Treasure Valley Homeowners Trust Us"
    items={[
      { title: 'Licensed & Insured' },
      { title: 'Transparent Pricing' },
      { title: 'Local Experts Who Know Boise' },
      { title: 'Satisfaction Guaranteed on Every Job' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80',
      alt: 'Homeowner and contractor shaking hands after completed project',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Built on Trust, Not Advertising</h3>
      We're a locally owned company that grew through word-of-mouth referrals from satisfied neighbors. We believe in honest
      assessments, fair pricing, and doing the job right the first time. When you call us, you're getting a team that treats
      your home like their own.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="how-it-works"
    tagline="Simple Process"
    title="Getting Started Is Easy"
    items={[
      {
        title: 'Tell Us About Your Project',
        description:
          'Describe what you need done through our online form, chat, or give us a call. We respond to every inquiry within 24 hours.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Get Your Free Estimate',
        description:
          "We'll review your project and provide a detailed, no-obligation estimate. No hidden fees, no surprises — just honest numbers.",
        icon: 'tabler:file-invoice',
      },
      {
        title: 'We Do the Work',
        description:
          'Our skilled team completes the job on time, on budget, and with care for your home. We clean up after ourselves, too.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Enjoy Your Home',
        description:
          'We follow up to make sure everything is perfect. Your satisfaction is guaranteed — if something isn\'t right, we\'ll fix it.',
        icon: 'tabler:home-check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Contractor reviewing renovation plans with homeowner',
    }}
  />

  <!-- Testimonials Widget ************ -->

  <Testimonials
    tagline="Reviews"
    title="What Our Neighbors Say"
    testimonials={[
      {
        testimonial:
          'Had a kitchen faucet that had been leaking for weeks. They came out the next day, diagnosed the problem in minutes, and had it replaced within the hour. Fair price, clean work, and they even noticed a slow drain under the sink and fixed that too. Highly recommend.',
        name: 'Sarah M.',
        job: 'North End, Boise',
      },
      {
        testimonial:
          'We hired them to paint our entire main floor — living room, kitchen, and hallway. The crew was professional, gave us great advice on colors, and finished a day ahead of schedule. The attention to detail around our trim and ceiling lines was impressive. Will definitely use again.',
        name: 'David & Lisa R.',
        job: 'Meridian',
      },
      {
        testimonial:
          "Signed up for their seasonal maintenance package last fall. They did a thorough inspection and caught a couple of issues with our weatherstripping and gutters that I never would have noticed. Saved us from what could have been an expensive repair this winter. Worth every penny.",
        name: 'Tom K.',
        job: 'Eagle',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Homes Served', amount: '500+' },
      { title: 'Years Experience', amount: '15+' },
      { title: 'Google Rating', amount: '4.9' },
      { title: 'Satisfaction Guaranteed', amount: '100%' },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    columns={2}
    items={[
      {
        title: 'How much do your services cost?',
        description:
          "We provide free, detailed estimates for every project. Costs vary based on scope and materials, but we're always transparent — no hidden fees.",
      },
      {
        title: 'What areas do you serve?',
        description:
          'We serve the entire Treasure Valley including Boise, Meridian, Eagle, Nampa, Caldwell, Star, and Kuna.',
      },
      {
        title: 'How quickly can you start?',
        description:
          'For most projects, we can schedule within 1–2 weeks. Emergency repairs are available with faster turnaround.',
      },
      {
        title: 'Are you licensed and insured?',
        description:
          "Yes. We are fully licensed and insured in the state of Idaho. We're happy to provide documentation upon request.",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Free Estimate',
        href: '/get-estimate',
        icon: 'tabler:clipboard-check',
      },
      {
        text: 'Call (208) XXX-XXXX',
        href: 'tel:+1208XXXXXXX',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">Ready to Get Started?</Fragment>

    <Fragment slot="subtitle">
      Tell us about your project and get a free, no-obligation estimate within 24 hours.
    </Fragment>
  </CallToAction>
</Layout>
